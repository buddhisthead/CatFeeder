#!/usr/bin/env python3
"""dispense — send a DISPENSE command to a CatFeeder over the network.

Connects to the feeder's TCP server, asks it to dispense food for a given amount of
food-flow time (in milliseconds), waits for the reply, and logs the result. Times out
after 10 seconds if the feeder never replies.

Usage:
    dispense <ip> [-p PORT] [-d MS]

Examples:
    dispense 10.1.1.143            # default duration on the default port
    dispense 10.1.1.143 -d 1500    # request 1500 ms of food-flow time
    dispense 10.1.1.143 -p 4242 -d 800
"""

import argparse
import socket
import sys

DEFAULT_PORT = 4242
DEFAULT_DURATION_MS = 800
REPLY_TIMEOUT_S = 10


def dispense(ip, port, duration_ms):
    """Send one DISPENSE command and return the feeder's reply line.

    Raises socket.timeout if no reply arrives within REPLY_TIMEOUT_S, or OSError on
    any connection failure.
    """
    with socket.create_connection((ip, port), timeout=REPLY_TIMEOUT_S) as sock:
        sock.settimeout(REPLY_TIMEOUT_S)
        sock.sendall(f"DISPENSE {duration_ms}\n".encode())

        # Read until we get a newline-terminated reply or the timeout fires.
        buf = bytearray()
        while b"\n" not in buf:
            data = sock.recv(64)
            if not data:
                break  # feeder closed the connection without a full reply
            buf.extend(data)
        return buf.decode(errors="replace").strip()


def main(argv=None):
    parser = argparse.ArgumentParser(
        description="Send a dispense command to a CatFeeder."
    )
    parser.add_argument("ip", help="IP address of the feeder")
    parser.add_argument(
        "-p", "--port", type=int, default=DEFAULT_PORT,
        help=f"feeder TCP port (default: {DEFAULT_PORT})",
    )
    parser.add_argument(
        "-d", "--duration", type=int, default=DEFAULT_DURATION_MS,
        metavar="MS",
        help=f"food-flow time in milliseconds (default: {DEFAULT_DURATION_MS})",
    )
    args = parser.parse_args(argv)

    target = f"{args.ip}:{args.port}"
    try:
        reply = dispense(args.ip, args.port, args.duration)
    except socket.timeout:
        print(f"ERROR: no reply from {target} within {REPLY_TIMEOUT_S}s (timed out)")
        return 1
    except OSError as exc:
        print(f"ERROR: could not reach {target}: {exc}")
        return 1

    if reply.startswith("DONE"):
        print(f"OK: {target} dispensed ({reply})")
        return 0
    if reply.startswith("ERR"):
        print(f"ERROR: feeder rejected command: {reply}")
        return 2
    print(f"ERROR: unexpected reply from {target}: {reply!r}")
    return 2


if __name__ == "__main__":
    sys.exit(main())
